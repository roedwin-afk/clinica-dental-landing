@import "tailwindcss";

@theme {
  --color-bg-main: #F6FAF9;
  --color-bg-alt: #EAF3F1;
  --color-text-main: #0B2B2A;
  --color-text-sec: #3E5A56;
  --color-brand-primary: #0E7C7B;
  --color-brand-dark: #0A5654;
  --color-accent: #FF6B4A;
  --color-accent-hover: #E85535;
  --color-border-color: #D8E6E4;

  --font-heading: "Fraunces", serif;
  --font-body: "Inter", sans-serif;

  --radius-md: 12px;
  --radius-lg: 24px;
}
</file>

<file path="tsconfig.json">
{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
</file>

<file path="astro.config.mjs">
// @ts-check
import { defineConfig } from 'astro/config';
import sitemap from '@astrojs/sitemap';

import tailwindcss from '@tailwindcss/vite';

export default defineConfig({
  // lo cambiás cuando tengas el dominio real del cliente
  site: 'https://github.com/roedwin-afk',
  base: '/clinica-dental-landing/',

  integrations: [sitemap()],

  vite: {
    plugins: [tailwindcss()],
  },
});
</file>

<file path="package.json">
{
  "name": "clinica-dental-landing",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
