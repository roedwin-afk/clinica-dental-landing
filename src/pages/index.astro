---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import WaveDivider from "../components/WaveDivider.astro";
import TrustBar from "../components/TrustBar.astro";
import Servicios from "../components/Servicios.astro";
import WhyUs from "../components/WhyUs.astro";
import CtaSection from "../components/CtaSection.astro";
import Footer from "../components/Footer.astro";

const whatsappNumber = "50364373092"; // Reemplazar con el número real del cliente
const whatsappMessage = "Hola, quisiera agendar una cita en Aqua Dental.";

---

<Layout
  title="Aqua Dental | Tu Clínica Dental en San Miguel"
  description="Clínica dental en San Miguel, El Salvador. Odontología general, ortodoncia y blanqueamiento. Agenda tu cita por WhatsApp."
  image="og-image.jpg"
>
  <Navbar 
    whatsappNumber={whatsappNumber}
    whatsappMessage={whatsappMessage}
  />
  <Hero 
    whatsappNumber={whatsappNumber}
    whatsappMessage={whatsappMessage}
  />
  <WaveDivider />
  <TrustBar />
  <Servicios />
  <WhyUs />
  <CtaSection
    whatsappNumber={whatsappNumber}
    whatsappMessage={whatsappMessage}
  />
  <Footer />
</Layout>
