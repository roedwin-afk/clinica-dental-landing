  {
    icon: 'M20 2H4C2.9 2 2 2.9 2 4V22L6 18H20C21.1 18 22 17.1 22 16V4C22 2.9 21.1 2 20 2Z',
    label: 'Citas rápidas y directas por WhatsApp',
