---

<section class="-mt-1 bg-bg-alt py-10">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="grid grid-cols-1 gap-6 text-center md:grid-cols-3">
      {
        trustItems.map((item) => (
          <div class="flex flex-col items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-primary text-white">
              <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current">
                <path d={item.icon} />
              </svg>
            </div>
            <span class="font-semibold text-text-main">{item.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>