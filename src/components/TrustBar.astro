---
const trustItems = [
  {
    icon: 'M12 17.27L18.18 21L16.54 13.97L22 9.24L14.81 8.63L12 2L9.19 8.63L2 9.24L7.46 13.97L5.82 21L12 17.27Z',
    label: 'Pacientes satisfechos con su experiencia',
  },
  {
    icon: 'M19 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM12 17C9.24 17 7 14.76 7 12C7 9.24 9.24 7 12 7C14.76 7 17 9.24 17 12C17 14.76 14.76 17 12 17ZM16.5 8.5C15.67 8.5 15 7.83 15 7C15 6.17 15.67 5.5 16.5 5.5C17.33 5.5 18 6.17 18 7C18 7.83 17.33 8.5 16.5 8.5Z',
    label: 'Casos reales de nuestros tratamientos',
