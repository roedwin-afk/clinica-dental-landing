---
interface Props {
  whatsappNumber?: string; // formato: 503XXXXXXXX, sin + ni espacios
  whatsappMessage?: string;
}

const {
  whatsappNumber = '50300000000', // PLACEHOLDER — reemplazar con el número real del cliente
  whatsappMessage = 'Hola, quisiera agendar una cita.',
} = Astro.props;

const whatsappHref = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<header class="bg-bg-main pt-20 md:pt-10">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="grid items-center gap-10 md:grid-cols-1 lg:grid-cols-2 text-center lg:text-left">
      <div>
        <h1 class="mb-5 font-heading text-4xl leading-tight tracking-tight lg:text-5xl">
          Sonrisas saludables que <span class="italic text-brand-primary">inspiran confianza</span>.
        </h1>
        <p class="mx-auto mb-8 max-w-[500px] text-lg text-text-sec lg:mx-0">
          Cuidado dental experto y cercano, con un trato profesional y humano en cada visita.
        </p>
        <div class="flex flex-wrap justify-center gap-4 lg:justify-start">
          
          <a  href={whatsappHref}
            class="inline-flex items-center justify-center rounded-full bg-accent px-7 py-3.5 font-semibold text-white shadow-[0_4px_12px_rgba(255,107,74,0.3)] transition hover:-translate-y-0.5 hover:bg-accent-hover"
          >
            Agenda por WhatsApp
          </a>
          
          <a  href="#servicios"
            class="inline-flex items-center justify-center rounded-full border-2 border-brand-primary px-7 py-3.5 font-semibold text-brand-primary transition hover:border-brand-dark hover:bg-bg-alt hover:text-brand-dark"
          >
            Ver tratamientos
          </a>
        </div>
      </div>

      <div class="relative flex items-center justify-center rounded-lg border border-border-color bg-gradient-to-br from-bg-alt to-bg-main p-10">
        <div class="relative z-[2] max-w-[380px] rounded-md bg-white p-8 shadow-md">
          <div class="mb-4 text-xl text-yellow-400">★★★★★</div>
          <p class="mb-6 font-heading italic text-text-main">
            "Me explicaron todo el proceso con paciencia. El consultorio es impecable, 100% recomendado."
          </p>
          <div class="flex items-center gap-3">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-brand-primary font-heading text-xl font-semibold text-white">
              M
            </div>
            <div>
              <h4 class="font-body text-base">Paciente satisfecha</h4>
              <p class="text-sm text-text-sec">Consulta reciente</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>